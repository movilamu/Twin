# Copy this file to .env.local for local development.
# On Vercel, add these same keys under Project Settings > Environment Variables.

# Groq API key (free) — https://console.groq.com/keys
GROQ_API_KEY=

# Supabase project URL and anon key — Project Settings > API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
